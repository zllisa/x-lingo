# 复制此文件为 .env，填入你的真实 Key

# DeepSeek AI — 口语对话
PUBLIC_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# Azure TTS — 韩语朗读
PUBLIC_AZURE_TTS_KEY=xxxxxxxxxxxxxxxx
PUBLIC_AZURE_TTS_REGION=eastasia

# Groq Whisper — 语音转文字（备用，国内直连不稳定）
PUBLIC_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx

# STT 引擎：azure（默认，走 Azure Batch，复用上面的 Azure 资源，国内可用）
#           或 groq（用 Groq Whisper，需科学上网）
PUBLIC_STT_PROVIDER=azure
